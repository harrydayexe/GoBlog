# GoBlogServ Environment Configuration
# Copy this file to .env and customize as needed

# Content Configuration
# Path to your markdown blog posts
GOBLOG_CONTENT_PATH=./posts

# Cache Configuration
# Enable in-memory caching with Ristretto
GOBLOG_CACHE_ENABLED=true

# Maximum cache size in megabytes
GOBLOG_CACHE_MAX_MB=100

# Cache TTL (time to live) - supports formats like: 30m, 1h, 2h30m
GOBLOG_CACHE_TTL=60m

# Search Configuration
# Enable full-text search with Bleve
GOBLOG_SEARCH_ENABLED=true

# Path to Bleve search index
GOBLOG_SEARCH_INDEX_PATH=./blog.bleve

# Rebuild search index on startup (set to true on first run)
GOBLOG_REBUILD_INDEX=false

# Blog Settings
# Number of posts to display per page
GOBLOG_POSTS_PER_PAGE=10

# Logging
# Enable verbose logging for debugging
GOBLOG_VERBOSE=false

# Note: Command-line flags take precedence over environment variables
# Example: goblogserv -verbose will override GOBLOG_VERBOSE
